# Copy this file to `.env` for local runs.
# Get DATABASE_URL from Supabase dashboard:
# Settings -> Database -> Connection string (PSQL URI)
# Append ?sslmode=require if needed.
DATABASE_URL=postgresql://postgres:CHANGE_ME_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

CRM_USERNAME=admin
CRM_PASSWORD=change-me
CRM_JSON_PATH=fullJSONs/all_enriched_leads.json
# Exa — https://dashboard.exa.ai/api-keys
EXA_API_KEY=
